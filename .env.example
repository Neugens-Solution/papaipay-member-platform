# Supabase PostgreSQL connection templates for future backend phases.
# Do not commit real credentials.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Vercel Blob object storage for listing hero/gallery image uploads.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"

# Strong random secret for signing portal sessions. Required in production.
AUTH_SESSION_SECRET="replace-with-a-strong-random-production-secret"
