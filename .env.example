# Supabase PostgreSQL connection templates for future backend phases.
# Do not commit real credentials.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Vercel Blob object storage for listing hero/gallery image uploads.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"

# Strong random secret for signing custom portal sessions.
# AUTH_SESSION_SECRET is preferred for custom portal sessions.
AUTH_SESSION_SECRET="replace-with-a-strong-random-production-secret"

# NEXTAUTH_SECRET is also supported as a session-secret fallback.
# Production/Preview Vercel environments must have at least one of
# AUTH_SESSION_SECRET or NEXTAUTH_SECRET configured.
# In practice, set both variables to the same strong random value to avoid
# deployment mistakes across custom portal sessions and NextAuth-compatible tooling.
NEXTAUTH_SECRET="replace-with-the-same-strong-random-production-secret"
